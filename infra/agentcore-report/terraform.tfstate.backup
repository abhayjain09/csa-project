            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"ReadBrowserJobs\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"sqs:ReceiveMessage\",\n        \"sqs:GetQueueAttributes\",\n        \"sqs:DeleteMessage\",\n        \"sqs:ChangeMessageVisibility\"\n      ],\n      \"Resource\": \"arn:aws:sqs:us-east-1:610639371721:edo-coanalyst-report-browser-jobs\"\n    },\n    {\n      \"Sid\": \"WriteBrowserResults\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"sqs:SendMessage\",\n      \"Resource\": \"arn:aws:sqs:us-east-1:610639371721:edo-coanalyst-report-browser-results\"\n    },\n    {\n      \"Sid\": \"WriteValidatedReports\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:PutObject\",\n        \"s3:ListBucket\",\n        \"s3:GetObject\"\n      ],\n      \"Resource\": [\n        \"arn:aws:s3:::edo-coanalyst-report-610639371721/*\",\n        \"arn:aws:s3:::edo-coanalyst-report-610639371721\"\n      ]\n    },\n    {\n      \"Sid\": \"WriteProvenance\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"dynamodb:UpdateItem\",\n        \"dynamodb:Query\",\n        \"dynamodb:PutItem\",\n        \"dynamodb:GetItem\"\n      ],\n      \"Resource\": [\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/edo-coanalyst-report-provenance/index/*\",\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/edo-coanalyst-report-provenance\"\n      ]\n    },\n    {\n      \"Sid\": \"ConfirmCandidate\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"bedrock:InvokeModelWithResponseStream\",\n        \"bedrock:InvokeModel\"\n      ],\n      \"Resource\": \"*\"\n    }\n  ]\n}",
