            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"DynamoPortalTables\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"dynamodb:UpdateItem\",\n        \"dynamodb:Scan\",\n        \"dynamodb:Query\",\n        \"dynamodb:PutItem\",\n        \"dynamodb:GetItem\",\n        \"dynamodb:DescribeTable\",\n        \"dynamodb:DeleteItem\",\n        \"dynamodb:BatchWriteItem\"\n      ],\n      \"Resource\": [\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/reportiq-web-queries/index/*\",\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/reportiq-web-queries\",\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/reportiq-runs/index/*\",\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/reportiq-runs\",\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/edo-coanalyst-report-provenance/index/*\",\n        \"arn:aws:dynamodb:us-east-1:610639371721:table/edo-coanalyst-report-provenance\"\n      ]\n    },\n    {\n      \"Sid\": \"S3ReportsBucket\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:PutObject\",\n        \"s3:ListBucketVersions\",\n        \"s3:ListBucket\",\n        \"s3:GetObject\",\n        \"s3:DeleteObjectVersion\",\n        \"s3:DeleteObject\"\n      ],\n      \"Resource\": [\n        \"arn:aws:s3:::edo-coanalyst-report-610639371721/*\",\n        \"arn:aws:s3:::edo-coanalyst-report-610639371721\"\n      ]\n    },\n    {\n      \"Sid\": \"AgentCoreInvoke\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"bedrock-agentcore:InvokeAgentRuntime\",\n      \"Resource\": \"arn:aws:bedrock-agentcore:us-east-1:610639371721:runtime/*\"\n    }\n  ]\n}",
